# =============================================================================
# Healthcare Policy & Claims Assistant — environment configuration
# Copy this file to `.env` and adjust values for your local environment.
# Never commit a real `.env` to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development
APP_NAME=healthcare-policy-claims-assistant
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Database (Postgres + pgvector)
#
# When the backend runs inside Docker Compose, the host is the service name
# `db`. When you run the backend directly on your machine, use `localhost`.
# -----------------------------------------------------------------------------
POSTGRES_USER=hpca
POSTGRES_PASSWORD=hpca_password
POSTGRES_DB=hpca
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Full SQLAlchemy URL used by the backend. If you set this directly it takes
# precedence over the individual POSTGRES_* parts above.
DATABASE_URL=postgresql+psycopg2://hpca:hpca_password@db:5432/hpca

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
BACKEND_PORT=8000

# -----------------------------------------------------------------------------
# Embeddings (used from Phase 3 onward)
#
# `EMBEDDING_PROVIDER` selects the backend implementation:
#   - `mock`            : deterministic mock vectors (default, no network)
#   - `openai`          : OpenAI-compatible /v1/embeddings endpoint
#   - `sentence-transformers` : local CPU model
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# LLM (used from Phase 4 onward)
#
# Defaults to `mock` so /rag/ask works without an API key. Switch to
# `openai` (which targets any OpenAI-compatible endpoint) for real
# generation. Point OPENAI_BASE_URL at:
#   - OpenAI proper : https://api.openai.com/v1
#   - Ollama        : http://localhost:11434/v1
#   - vLLM          : http://localhost:8000/v1
#   - LM Studio     : http://localhost:1234/v1
# -----------------------------------------------------------------------------
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
# `strict` — OpenAI proper, guaranteed schema adherence via json_schema.
# `json_object` — Ollama / vLLM / LM Studio, looser JSON-only mode.
LLM_STRUCTURED_OUTPUT=json_object

# -----------------------------------------------------------------------------
# RAG defaults (used from Phase 2/3 onward)
# -----------------------------------------------------------------------------
CHUNK_SIZE=800
CHUNK_OVERLAP=120
DEFAULT_TOP_K=5

# Hybrid search: 0.0 = pure keyword, 1.0 = pure vector.
HYBRID_ALPHA=0.6
FTS_LANGUAGE=english

# -----------------------------------------------------------------------------
# Document ingestion (Phase 2)
# -----------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=10

# -----------------------------------------------------------------------------
# Auth (Phase 9 — placeholder, OFF by default)
#
# With AUTH_ENABLED=false every request is the anonymous viewer and no token
# is required (the demo default). Set it to true to require a valid JWT bearer
# token on endpoints that depend on get_current_user / require_role.
#
# JWT_SECRET MUST be replaced in any real deployment — inject it from a secret
# manager, never commit it. The default below is intentionally insecure.
# -----------------------------------------------------------------------------
AUTH_ENABLED=false
JWT_SECRET=dev-insecure-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
