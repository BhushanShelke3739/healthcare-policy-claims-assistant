# Where the FastAPI backend lives. `NEXT_PUBLIC_` prefix is required so
# the value is inlined at build time for the browser bundle.
#
# Defaults assume:
#   - Backend is running on http://localhost:8000 (uvicorn in your venv
#     OR `docker compose up backend`)
#   - Frontend is running on http://localhost:3000 (Next.js dev server)
#
# Note: the backend's CORS_ORIGINS setting must include
# http://localhost:3000 (it does by default — see backend/app/core/config.py).
NEXT_PUBLIC_API_URL=http://localhost:8000
